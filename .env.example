# Copy this file to `.env` and adjust values for your machine.

# Local MySQL connection used by the backend container.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=ecommerce_analysis
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# Shared public-task runtime options
PUBLIC_TASK_PYTHON=python3
PUBLIC_TASK_BROWSER_PATH=
PUBLIC_TASK_BROWSER_CHANNEL=chrome
PUBLIC_TASK_BROWSER_PROFILE_DIR=../runtime/browser-profile
PUBLIC_TASK_WORKER_URL=http://public-task-worker:8090
PUBLIC_TASK_WORKSPACE_ROOT=/workspace
PUBLIC_TASK_CDP_URL=http://host.docker.internal:9223

# Example values:
# Linux host:
# PUBLIC_TASK_PYTHON=/usr/bin/python3
# PUBLIC_TASK_BROWSER_PATH=/usr/bin/chromium
#
# Windows host:
# PUBLIC_TASK_PYTHON=C:/Python311/python.exe
# PUBLIC_TASK_BROWSER_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
#
# Local MySQL on the host machine:
# MYSQL_HOST=host.docker.internal
# MYSQL_PORT=3306
# MYSQL_DATABASE=ecommerce_analysis
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=your-local-mysql-password
#
# Docker worker:
# PUBLIC_TASK_PYTHON=/usr/bin/python3
# PUBLIC_TASK_BROWSER_PATH=/usr/bin/chromium
# PUBLIC_TASK_BROWSER_PROFILE_DIR=/workspace/runtime/browser-profile
# PUBLIC_TASK_WORKER_URL=http://public-task-worker:8090
# PUBLIC_TASK_WORKSPACE_ROOT=/workspace
# PUBLIC_TASK_CDP_URL=http://host.docker.internal:9223
