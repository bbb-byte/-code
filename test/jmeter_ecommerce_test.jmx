          <intProp name="HTTPSampler.response_timeout">60000</intProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- 聚合报告 -->
        <ResultCollector guiclass="StatVisualizer" testclass="ResultCollector" testname="聚合报告-RFM接口" enabled="true">
